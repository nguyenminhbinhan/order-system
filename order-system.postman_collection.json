            "body": { "mode": "raw", "raw": "{\n  \"name\": \"User 1\",\n  \"role\": \"customer\",\n  \"email\": \"user1@test.com\",\n  \"password\": \"password1\",\n  \"address\": \"Street 1\"\n}" },
            "url": { "raw": "http://localhost:3000/users", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users"] }
          }
        },
        { "name": "Get users", "request": { "method": "GET", "url": { "raw": "http://localhost:3000/users", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users"] } } },
        { "name": "Get user by id", "request": { "method": "GET", "url": { "raw": "http://localhost:3000/users/{{userId}}", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users", "{{userId}}"] } } },
        { "name": "Update user", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"User 1 Updated\",\n  \"address\": \"New Street\"\n}" }, "url": { "raw": "http://localhost:3000/users/{{userId}}", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users", "{{userId}}"] } } },
